# Gemini API Configuration
GEMINI_API_KEY=api_key_goes_here

# Model Settings
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.1          # Creativity of the responce
GEMINI_TOP_P=0.1                # Variation of vocabulary
GEMINI_TOP_K=10                 # Output predictability 
GEMINI_MAX_TOKENS=2048          # Response size